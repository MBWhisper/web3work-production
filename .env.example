# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://your-domain.vercel.app
NODE_ENV=production
PORT=5000

# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Create project at https://supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...  # Never expose in frontend!
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-string-min-32-chars
# Generate: openssl rand -hex 32

# ─── Lemon Squeezy ────────────────────────────────────────────────────────────
# Sign up at https://app.lemonsqueezy.com/register
# API Keys → Settings → API
LEMONSQUEEZY_API_KEY=eyJ0eXAi...
LS_STORE_ID=12345
LS_WEBHOOK_SECRET=your-webhook-signing-secret

# Product Variant IDs (from Lemon Squeezy → Products → Variants)
LS_VARIANT_BASIC=111111
LS_VARIANT_PREMIUM=222222
LS_VARIANT_ENTERPRISE=333333
LS_VARIANT_JOB_STANDARD=444444   # $9.99 one-time job post
LS_VARIANT_JOB_FEATURED=555555   # $29.99 featured job post

# ─── Crypto (BSC / BUSD) ──────────────────────────────────────────────────────
# Your BSC wallet address that receives BUSD payments
PLATFORM_WALLET_ADDRESS=0x...YourBSCWalletAddress

# ─── Email (optional — SMTP) ──────────────────────────────────────────────────
# Use Gmail App Password or SendGrid/Mailgun
EMAIL_FROM=noreply@web3work.io
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password  # Gmail: App Password (not regular password)

# ─── Frontend (Vite — must prefix with VITE_) ─────────────────────────────────
# These are exposed to the browser
VITE_PLATFORM_WALLET=0x...YourBSCWalletAddress
VITE_BUSD_CONTRACT=0xe9e7CEA3DedcA5984780Bafc599bD69ADd087D56
VITE_BSC_RPC=https://bsc-dataseed.binance.org/
VITE_APP_NAME=Web3Work

# ─── Optional: Vercel KV / Upstash (for production rate limiting) ─────────────
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
